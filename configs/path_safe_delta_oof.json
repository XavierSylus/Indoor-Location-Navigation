{
  "version": "v008_path_safe_delta_oof",
  "experiment_type": "cv_probe",
  "iteration_mode": "add_module",
  "competition_slug": "indoor-location-navigation",
  "seed": 42,
  "data": {
    "n_time_steps": 100,
    "imu_channels": 12,
    "aux_feature_dim": 16,
    "batch_size": 256,
    "num_workers": 2,
    "noise_std": 0.02,
    "internal_validation_fraction": 0.15,
    "target_site_ids": [
      "5d27099f03f801723c32511d",
      "5da138274db8ce0c98bbd3d2",
      "5da138364db8ce0c98bc00f1",
      "5da1383b4db8ce0c98bc11ab",
      "5da138754db8ce0c98bca82f"
    ],
    "heldout_path_ids": [
      "5dc65d451cda3700060305be",
      "5dce63105516ad00065f0280",
      "5dce818894e4900006125129",
      "5dd0e5dd878f3300066c7644",
      "5dd374ae44333f00067aa196"
    ]
  },
  "model": {
    "family": "imu_delta_v3",
    "cnn": {
      "channels": [12, 32, 64, 128],
      "kernel_sizes": [5, 5, 3],
      "dropout": 0.15
    },
    "gru": {
      "hidden_size": 128,
      "num_layers": 2,
      "dropout": 0.15,
      "bidirectional": true
    },
    "mlp_aux": {
      "hidden_sizes": [64, 32],
      "dropout": 0.15
    },
    "head": {
      "hidden_sizes": [256, 128],
      "dropout": 0.25,
      "output_dim": 2
    }
  },
  "training": {
    "n_cycles": 3,
    "cycle_lr_decay": 0.5,
    "gradient_clip": 5.0,
    "patience": 15,
    "amp": true,
    "phase_a": {
      "optimizer": "adam",
      "lr": 0.001,
      "weight_decay": 0.0001,
      "loss": "delta_distance",
      "loss_params": {"alpha": 1.0, "beta": 0.5, "gamma": 0.3},
      "epochs": 40,
      "scheduler": "cosine_warmup",
      "warmup_epochs": 3
    },
    "phase_b": {
      "optimizer": "sgd",
      "lr": 0.001,
      "momentum": 0.9,
      "weight_decay": 0.00001,
      "loss": "delta_distance",
      "loss_params": {"alpha": 1.0, "beta": 0.8, "gamma": 0.5},
      "epochs": 25,
      "scheduler": "cosine",
      "warmup_epochs": 0
    }
  },
  "lattice": {
    "version": "v008_path_safe_delta_oof",
    "experiment_type": "cv_probe",
    "iteration_mode": "add_module",
    "random_seed": 42,
    "inputs": {
      "candidate_dataset": "data_processing/processed/hard_site_candidate_rerank_dataset.csv",
      "v3_delta_predictions": "/kaggle/working/path_safe_v3_delta_oof.csv"
    },
    "outputs": {
      "selections": "/kaggle/working/path_safe_lattice_selections.csv",
      "summary": "/kaggle/working/path_safe_lattice_summary.json"
    },
    "reranker": {
      "feature_set": "geometry_source_wifi",
      "target": "label_log1p_distance_m",
      "model_type": "lgbm",
      "num_leaves": 7,
      "min_child_samples": 20,
      "learning_rate": 0.05,
      "n_estimators": 300,
      "reg_alpha": 1.0,
      "reg_lambda": 5.0,
      "subsample": 0.8,
      "colsample_bytree": 0.8
    },
    "transition": {
      "alpha_grid": [0.0, 0.1, 0.25, 0.5, 1.0, 2.0, 4.0],
      "pairwise_cap_m": 10.0,
      "require_exact_v3_chain": true,
      "calibration": "leave_one_path_out"
    },
    "success_gate": {
      "baseline_mae_m": 7.524908431950883,
      "target_mae_m": 3.0,
      "minimum_excess_over_4m_reduction_ratio": 0.25
    },
    "leakage_boundary": {
      "submission_safe": false,
      "reason": "Delta predictions are path-safe for the five diagnostic paths; coverage is not yet submission-wide.",
      "forbidden_transition_columns": [
        "gt_delta_x",
        "gt_delta_y",
        "gt_x",
        "gt_y",
        "label_distance_m",
        "group_oracle_distance_at_topk"
      ]
    }
  },
  "outputs": {
    "predictions": "/kaggle/working/path_safe_v3_delta_oof.csv",
    "split_manifest": "/kaggle/working/path_safe_split_manifest.csv",
    "lattice_selections": "/kaggle/working/path_safe_lattice_selections.csv",
